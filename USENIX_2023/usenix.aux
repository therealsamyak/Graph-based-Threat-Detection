\@writefile{lof}{\contentsline {figure}{\numberline {8}{\ignorespaces Graph snapshot of the combined flow + authentication network. High-degree hub nodes (domain controllers, file servers) are visible as central clusters. Red-team edges create structural anomalies by connecting hubs to previously unseen destinations. \textit  {(Figure by: Wesley Gunawan)}}}{6}{figure.8}\protected@file@percent }
\newlabel{fig:graph}{{8}{6}{Graph snapshot of the combined flow + authentication network. High-degree hub nodes (domain controllers, file servers) are visible as central clusters. Red-team edges create structural anomalies by connecting hubs to previously unseen destinations. \textit {(Figure by: Wesley Gunawan)}}{figure.8}{}}
