\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Protocol distribution: red-team flows are 99.82\% TCP (LANL) and 100\% TCP (DAPT2020), while benign traffic is roughly 50\% TCP. This structural difference provides a strong detection signal. \textit  {(Figure by: Ibrahim Pehlivan)}}}{3}{figure.1}\protected@file@percent }
\newlabel{fig:protocol}{{1}{3}{Protocol distribution: red-team flows are 99.82\% TCP (LANL) and 100\% TCP (DAPT2020), while benign traffic is roughly 50\% TCP. This structural difference provides a strong detection signal. \textit {(Figure by: Ibrahim Pehlivan)}}{figure.1}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Fan-out ratio across kill-chain stages: reconnaissance (2.50), foothold (2.70), lateral movement (6.00), exfiltration (1.00). The jump from 2.5 to 6.0 signals the transition to lateral movement. \textit  {(Figure by: Ibrahim Pehlivan)}}}{4}{figure.2}\protected@file@percent }
\newlabel{fig:fanout}{{2}{4}{Fan-out ratio across kill-chain stages: reconnaissance (2.50), foothold (2.70), lateral movement (6.00), exfiltration (1.00). The jump from 2.5 to 6.0 signals the transition to lateral movement. \textit {(Figure by: Ibrahim Pehlivan)}}{figure.2}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {5.2}Method Comparison}{4}{subsection.5.2}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces ROC curves comparing detection performance of flow-only, auth-only, and combined methods on LANL-2015. The combined method (AUC = 0.9456) dominates both single-source baselines, demonstrating that multi-log integration improves the trade-off between true positive rate and false positive rate. \textit  {(Figure by: Wesley Gunawan)}}}{4}{figure.3}\protected@file@percent }
\newlabel{fig:roc}{{3}{4}{ROC curves comparing detection performance of flow-only, auth-only, and combined methods on LANL-2015. The combined method (AUC = 0.9456) dominates both single-source baselines, demonstrating that multi-log integration improves the trade-off between true positive rate and false positive rate. \textit {(Figure by: Wesley Gunawan)}}{figure.3}{}}
