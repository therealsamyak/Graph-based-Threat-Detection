\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Composite anomaly scores: red-team edges score 1.59$\times $ higher than baseline (mean 0.85 vs. 0.53). The four-component scoring function (source suspiciousness, edge rarity, TCP signal, lateral movement ports) successfully differentiates attack traffic. \textit  {(Figure by: Samyak Kakatur)}}}{5}{figure.5}\protected@file@percent }
\newlabel{fig:scoring}{{5}{5}{Composite anomaly scores: red-team edges score 1.59$\times $ higher than baseline (mean 0.85 vs. 0.53). The four-component scoring function (source suspiciousness, edge rarity, TCP signal, lateral movement ports) successfully differentiates attack traffic. \textit {(Figure by: Samyak Kakatur)}}{figure.5}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {5.6}Detection Timeline}{5}{subsection.5.6}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces Anomaly score distribution for red-team edges (orange) versus baseline edges (blue). Red-team edges cluster at higher scores (mean = 0.85 vs. 0.53), but distribution overlap limits threshold-based recall. \textit  {(Figure by: Wesley Gunawan)}}}{6}{figure.6}\protected@file@percent }
\newlabel{fig:scores}{{6}{6}{Anomaly score distribution for red-team edges (orange) versus baseline edges (blue). Red-team edges cluster at higher scores (mean = 0.85 vs. 0.53), but distribution overlap limits threshold-based recall. \textit {(Figure by: Wesley Gunawan)}}{figure.6}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces Detection timeline showing anomalous edges (blue) overlaid with red-team activity windows (orange). Detections cluster around active attack periods, confirming temporal responsiveness of the graph-based method. \textit  {(Figure by: Ibrahim Pehlivan)}}}{6}{figure.7}\protected@file@percent }
